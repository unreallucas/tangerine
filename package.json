{
  "name": "@dinhtungdu/tangerine",
  "version": "0.0.3",
  "description": "Local background coding agent platform with multi-provider support and web dashboard",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-import-x": "^4.16.2",
    "husky": "^9.1.7",
    "typescript-eslint": "^8.57.0"
  },
  "bin": {
    "tangerine": "bin/tangerine"
  },
  "files": [
    "bin/",
    "dist/",
    "packages/",
    "scripts/",
    "web/dist/",
    "skills/",
    ".agents/skills/"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:api": "bun run --filter tangerine-server dev",
    "dev:web": "bun run --filter tangerine-web dev",
    "build": "bun run --filter tangerine-web build",
    "build:dev": "bun run --filter tangerine-web build:dev",
    "lint": "eslint 'packages/*/src/**/*.ts' 'web/src/**/*.{ts,tsx}'",
    "build:cli": "bun build packages/server/src/cli/index.ts --target bun --outfile dist/cli.js --external 'bun:*' --external bun-pty --external effect --external hono --external 'hono/*' --external cron-parser --external '@opencode-ai/sdk' --external zod",
    "check": "bun run --filter '*' check && bun run lint",
    "test": "bun run --filter '*' test",
    "prepublishOnly": "bun run build:cli",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/*",
    "web"
  ],
  "dependencies": {
    "@opencode-ai/sdk": "^1.3.2",
    "bun-pty": "^0.4.8",
    "cron-parser": "^5.5.0",
    "effect": "^3.12",
    "hono": "^4.7",
    "zod": "^3.24"
  }
}
